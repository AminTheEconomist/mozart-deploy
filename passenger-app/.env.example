# Copy this to .env (gitignored). Most fields are OPTIONAL.

# --- Claude analyzer -------------------------------------------------------
# No API key needed — the analyzer shells out to `claude` CLI which uses your
# Max subscription via OAuth. One-time setup: run `claude /login` once.
#
# Optional: override path to the claude binary (default /opt/homebrew/bin/claude)
# CLAUDE_BIN=/opt/homebrew/bin/claude
# Optional: pin a specific model (default = Claude Code's default)
# CLAUDE_MODEL=claude-sonnet-4-5

# --- ElevenLabs (for generate-audio.js, the friend's-voice TTS) -----------
ELEVENLABS_API_KEY=sk_your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id
# Optional
# ELEVENLABS_MODEL=eleven_turbo_v2_5
